# =============================================================================
# Root `.env` — used by: api-server (dotenv), lib/db (drizzle + runtime pool)
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# --- Runtime ---
NODE_ENV=development
# production on Render/Railway/Vercel serverless workers, etc.

# --- Database (required) ---
# Postgres URL (Supabase direct or pooler). Special chars in password: URL-encode (# → %23, @ → %40).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Set only if you must disable TLS for pg (local edge cases). Cloud Supabase: omit or leave unset.
# DATABASE_SSL=disable

# --- Auth (required in production) ---
JWT_SECRET=change-me-min-32-chars-use-openssl-rand-hex-32
JWT_EXPIRY=24h

# --- HTTP server ---
# Local: 3000. Render/Railway usually inject PORT — still set in .env locally.
PORT=3000

# --- Public app URL (password reset links, checker dashboard links) ---
APP_URL=http://localhost:5173

# --- Email (Resend) — optional; alerts/forgot-password skip email if unset ---
RESEND_API_KEY=
EMAIL_FROM=alerts@yourdomain.com

# --- Cron: API key for POST /api/cron/* (GitHub Actions `scripts/run-checks.ts` uses same key) ---
# Generate: openssl rand -hex 32
CRON_API_KEY=

# --- One-time admin bootstrap (set on host, redeploy, log in, then remove ADMIN_SEED_PASSWORD) ---
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Admin

# --- Logging ---
LOG_LEVEL=info

# =============================================================================
# GitHub Actions — Repository secrets (not in .env file on disk)
# Settings → Secrets and variables → Actions
# =============================================================================
# API_URL          = Public API base, e.g. https://your-api.onrender.com
# CRON_API_KEY     = Same value as CRON_API_KEY above
# DATABASE_URL     = Same as backend (if workflow needs DB; see workflow file)
# JWT_SECRET       = Same as backend (only if script/workflow needs it)
# RESEND_API_KEY   = If workflow sends mail
# EMAIL_FROM       = If workflow sends mail
# APP_URL          = Frontend URL

# =============================================================================
# Frontend — optional `artifacts/monitor-app/.env.local` (Vite)
# =============================================================================
# Dev proxy target (default http://localhost:3000)
# API_BASE_URL=http://localhost:3000
# Dev server port
# PORT=5173
# If app is hosted under a subpath
# BASE_PATH=/
# Only if API is NOT same-origin (no Vercel /api rewrite). Example direct Render URL:
# VITE_API_URL=https://your-api.onrender.com
# Vite injects BASE_URL from `base` in vite.config — usually leave unset.
