# Database
DATABASE_URL=postgresql://user:password@localhost:5432/404monitor
# Optional: set to disable if your local Postgres URL is not on localhost but has no TLS
# DATABASE_SSL=disable

# JWT Authentication
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_EXPIRY=24h

# Server
PORT=3000

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=alerts@yourdomain.com

# Optional: first deploy only — create admin user, then remove ADMIN_SEED_PASSWORD from the host
# ADMIN_SEED_EMAIL=you@example.com
# ADMIN_SEED_PASSWORD=choose-a-strong-password
# ADMIN_SEED_NAME=Your Name
