{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://workspaceapi-server-production-b33f.up.railway.app/api/:path*"
    }
  ],
  "fallback": {
    "rewrite": "/index.html"
  }
}
