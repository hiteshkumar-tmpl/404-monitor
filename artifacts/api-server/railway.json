{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "node": "20"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "sleep": true,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/api/health"
  }
}
